# PDF Batch Compressor Environment Configuration

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost

# CORS Settings
CORS_ORIGIN=*

# PDF Compression Settings
COMPRESSION_RATIO=0.2        # 0.2 = 20% of original size
MAX_FILES=10                 # Maximum files per batch
MAX_FILE_SIZE=157286400      # 150MB in bytes

# Ghostscript Configuration
USE_GHOSTSCRIPT=true         # Enable for better compression
GHOSTSCRIPT_QUALITY=ebook    # screen, ebook, printer, prepress

# Temporary Files
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
CLEANUP_INTERVAL=1800000     # 30 minutes in milliseconds
TEMP_FILE_MAX_AGE=3600000    # 1 hour in milliseconds

# Logging
LOG_LEVEL=info               # error, warn, info, debug
LOG_FILE=./logs/app.log

# Performance
MAX_CONCURRENT_JOBS=5        # Maximum concurrent compressions
REQUEST_TIMEOUT=60000        # Request timeout in ms
STREAM_BUFFER_SIZE=65536     # Buffer size for streaming

# Security
RATE_LIMIT_WINDOW=900000     # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window per IP
ENABLE_HTTPS=false
SSL_KEY_PATH=./ssl/key.pem
SSL_CERT_PATH=./ssl/cert.pem

# API Configuration
API_PREFIX=/api
HEALTH_CHECK_INTERVAL=30000  # 30 seconds

# Database (optional for future features)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pdf_compressor
DB_USER=postgres
DB_PASSWORD=

# Storage (optional for cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Development
DEBUG=false
MOCK_COMPRESSION=false       # Use mock compression for testing
